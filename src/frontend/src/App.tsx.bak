const FALLBACK_GRADIENT = "linear-gradient(135deg, #0a6430 0%, #0b7a3b 100%)";

type CartItem = { name: string; price: number; quantity: number };
type OfferState = { discountPercent: number; active: boolean };

export type OrderRecord = {
  orderNo: string;
  date: string; // ISO string
  customerName: string;
  phone: string;
  address: string;
  items: CartItem[];
  discount: number; // percent
  discountAmount: number;
  originalTotal: number;
  total: number;
  paymentMethod: string;
};

const ADMIN_PASSWORD = "8228096793";

function orderToRecord(order: Order): OrderRecord {
  const subtotal = Number(order.subtotal);
  const total = Number(order.totalAmount);
  const discount = Number(order.discountPercent);
  const discountAmount = subtotal - total;
  const dateIso = new Date(Number(order.timestamp) / 1_000_000).toISOString();
  return {
    orderNo: String(order.orderId).padStart(3, "0"),
    date: dateIso,
    customerName: order.customerName,
    phone: order.customerPhone,
    address: order.customerAddress,
    items: order.items.map((i) => ({
      name: i.itemName,
      price: Number(i.price),
      quantity: Number(i.quantity),
    })),
    discount,
    discountAmount,
    originalTotal: subtotal,
    total,
    paymentMethod: order.paymentMethod,
  };
}

function formatDate(iso: string) {
  const d = new Date(iso);
  return d.toLocaleDateString("en-IN", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  });
}

function formatTime(iso: string) {
  const d = new Date(iso);
  return d.toLocaleTimeString("en-IN", {
    hour: "2-digit",
    minute: "2-digit",
    hour12: true,
  });
}
